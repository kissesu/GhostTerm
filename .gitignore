# ============================================
# Node.js / pnpm
# ============================================
node_modules/
pnpm-debug.log*

# ============================================
# Vite 构建产物
# ============================================
dist/
dist-ssr/

# ============================================
# Tauri 构建产物（Rust 侧由 src-tauri/.gitignore 管理）
# ============================================
src-tauri/target/

# ============================================
# 测试产物
# ============================================
coverage/

# ============================================
# Git Worktree 目录
# 项目使用 worktree 做特性隔离开发，目录名以项目名开头
# ============================================
GhostTerm-feat-*/
ghostterm-worktrees/

# ============================================
# AI 工具本地配置（会话级别，不应进入版本控制）
# ============================================
.claude/
.superpowers/

# ============================================
# 编辑器 / IDE
# ============================================
.vscode/*
!.vscode/extensions.json
.idea/
*.sw?

# ============================================
# 操作系统
# ============================================
.DS_Store
Thumbs.db

# ============================================
# 环境变量 / 密钥（Tauri 签名等）
# ============================================
.env
.env.*
*.key
*.pem

# ============================================
# 杂项
# ============================================
*.local
*.log
RESEARCH.md
