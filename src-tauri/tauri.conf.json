{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GhostTerm",
  "version": "0.2.0",
  "identifier": "com.atlas.ghostterm",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GhostTerm",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "backgroundColor": "#1a1b26",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGREE5OTcxNTdBRjNEREYKUldUZlBhOVhjWm5hdndORVFhUFMzR21LOU91TE5uaFIrSEY3UTkyaGdYcDc0b3RidjNZbTVaOEEK",
      "endpoints": [
        "http://localhost:8745/mock-update.json",
        "https://github.com/kissesu/GhostTerm/releases/latest/download/latest.json"
      ]
    }
  }
}
