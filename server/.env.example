# @file .env.example
# @description 进度模块本地开发环境变量样板。
#              拷贝为 .env，server 启动时 godotenv 自动加载（生产部署不读）。
# @author Atlas.oi
# @date 2026-04-29

# ─────── 必填（缺失即拒绝启动） ───────

# Postgres 连接串。本地默认匹配 docker-compose.yml
DATABASE_URL=postgres://postgres:devpass@localhost:5432/progress?sslmode=disable

# JWT 密钥（HMAC，至少 32 字节）。本地随便设；生产从 secrets 注入
JWT_ACCESS_SECRET=dev-access-secret-32-bytes-min!!
JWT_REFRESH_SECRET=dev-refresh-secret-32-bytes-min!

# ─────── 可选（不填用默认） ───────

# HTTP 监听
HTTP_ADDR=:8080

# JWT TTL（time.Duration 字面量）
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# bcrypt cost；生产 ≥10
BCRYPT_COST=10

# 文件落盘根目录 + 单文件上限
FILE_STORAGE_PATH=./data/files
FILE_MAX_SIZE_MB=100
